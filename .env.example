# IONS Genesis — Environment Variables
# Copy this file to .env and fill in your values

# Database — matches docker-compose.yml defaults
DATABASE_URL=postgresql://ions:ions@localhost:5432/ions
POSTGRES_USER=ions
POSTGRES_PASSWORD=ions
POSTGRES_DB=ions

# Required: OpenRouter API key for CBB extraction and relationship generation
# Get one free at https://openrouter.ai
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model for traversal and synthesis
# Any model on OpenRouter works — see https://openrouter.ai/models
DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct

# Node identity
IONS_NODE_ID=genesis_node

# Federation — set this to your public URL when deploying
# Used in the node manifest so other nodes can discover and query you
PUBLIC_API_BASE=http://localhost:8000
NODE_DESCRIPTION=My IONS node

# Security
AUTH_SECRET=changeme

# Environment
ENV=local